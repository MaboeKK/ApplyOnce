# packages/api/.env.example
# Copy to .env and fill in. NEVER commit .env.
# NOTE: ports chosen to avoid conflicts on the shared kmaboe sandbox.

# ─── DATABASE (postgres on host port 5433, not 5432) ─────────────────────────
DATABASE_URL="postgresql://applyonce:applyonce_dev_password@localhost:3610/applyonce"

# ─── REDIS (host port 6380, not 6379 — 6379 belongs to GoTurbo) ──────────────
REDIS_URL="redis://localhost:3611"

# ─── SERVER ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3600                      # API — safe port from approved list

# ─── PORTAL / ADMIN URLs (for CORS) ──────────────────────────────────────────
PORTAL_URL=http://localhost:3601
ADMIN_URL=http://localhost:3602
CORS_ORIGINS=http://localhost:3601,http://localhost:3602

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_SECURE_RANDOM_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── PAYGATE (mocked in dev) ─────────────────────────────────────────────────
PAYGATE_ID=10011072130
PAYGATE_SECRET=secret
PAYGATE_SANDBOX=true

# ─── STORAGE ─────────────────────────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/home/kmaboe/applyonce/uploads

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── EMAIL (verification on signup) ──────────────────────────────────────────
# dev = show verification code on screen (no email server needed — use for demo)
# production = send via SMTP
EMAIL_MODE=dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ApplyOnce <no-reply@applyonce.co.za>"
